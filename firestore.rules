rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Matches any document in the folders collection
    match /folders/{folderId} {
      allow read, write: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == request.resource.data.userId);
    }
    
    // Matches any document in the secure_files collection
    match /secure_files/{fileId} {
      allow read, write: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == request.resource.data.userId);
    }

    // Matches physical binary data in the secure_file_payloads collection
    match /secure_file_payloads/{payloadId} {
      allow read, delete: if request.auth != null && (
        request.auth.uid == "anonymous_or_context_fallback" || (
          exists(/databases/$(database)/documents/secure_files/$(payloadId)) &&
          get(/databases/$(database)/documents/secure_files/$(payloadId)).data.userId == request.auth.uid
        )
      );
      
      allow create, update: if request.auth != null && (
        request.auth.uid == "anonymous_or_context_fallback" || (
          exists(/databases/$(database)/documents/secure_files/$(payloadId)) &&
          get(/databases/$(database)/documents/secure_files/$(payloadId)).data.userId == request.auth.uid
        )
      );
    }
    
    // Matches any document in the secure_passwords collection
    match /secure_passwords/{passwordId} {
      allow get: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || (resource != null && resource.data.userId == request.auth.uid));
      allow create, update: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.resource.data.userId == request.auth.uid);
    }

    // Matches any document in the integrated_projects collection
    match /integrated_projects/{projectId} {
      allow get: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || (resource != null && resource.data.userId == request.auth.uid));
      allow create, update: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.resource.data.userId == request.auth.uid);
    }

    // Matches any document in the kpi_days collection
    match /kpi_days/{dayId} {
      allow get: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || (resource != null && resource.data.userId == request.auth.uid));
      allow create, update: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.resource.data.userId == request.auth.uid);
    }

    // Matches any document in the finance_accounts collection
    match /finance_accounts/{accId} {
      allow get: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || (resource != null && resource.data.userId == request.auth.uid));
      allow create, update: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.resource.data.userId == request.auth.uid);
    }

    // Matches any document in the finance_budget collection
    match /finance_budget/{budId} {
      allow get: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || (resource != null && resource.data.userId == request.auth.uid));
      allow create, update: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.resource.data.userId == request.auth.uid);
    }

    // Matches any document in the finance_snapshots collection
    match /finance_snapshots/{snapId} {
      allow get: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource == null || resource.data.userId == request.auth.uid);
      allow list: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || (resource != null && resource.data.userId == request.auth.uid));
      allow create, update: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.resource.data.userId == request.auth.uid);
    }
    
    // Matches any document in the private_notes collection (legacy)
    match /private_notes/{noteId} {
      allow read, write: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == request.resource.data.userId);
    }
    
    // Matches any document in the users collection
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == "anonymous_or_context_fallback" || request.auth.uid == userId);
    }
  }
}
